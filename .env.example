DDT_HOME=~/DDT
OLLAMA_BASE_URL=http://localhost:11434
DDT_PIPELINE=ocr_struct
DDT_OCR_MODEL=glm-ocr:latest
DDT_STRUCT_MODEL=qwen3.5:4b
DDT_VISION_MODEL=qwen3.5:4b
DDT_RENDER_DPI=250
DDT_MIN_NATIVE_TEXT_CHARS=200
DDT_FILE_STABILITY_SECONDS=3
DDT_REQUEST_TIMEOUT_SECONDS=180
DDT_MAX_RETRIES=3
DDT_SEED=42
DDT_KEEP_RAW_OCR=true
DDT_UNLOAD_MODELS=true
DDT_OCR_TABLE_PASS=false
DDT_LOG_LEVEL=INFO
